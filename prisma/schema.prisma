generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String   @id @default(uuid())
  name            String
  institute       String
  address         String
  phone           String
  email           String
  tenantName      String   @unique
  instituteNumber String?  // e.g. "2.2" used as section prefix in printed reports
  users           User[]
  requests        LicenseRequest[]
  allocations     LicenseAllocation[]
  cpsGiven        CpsTransaction[] @relation("CpsFromOrg")
  cpsReceived     CpsTransaction[] @relation("CpsToOrg")
  
  // ICT Survey Relations
  ictSurveys      IctSurvey[]
  m365UserMaps    M365UserDeviceMap[]
}

model User {
  id                  String        @id @default(uuid())
  nationalId          String        @unique
  fullName            String
  officeEmail         String        @unique
  officePhone         String?
  mobile              String?
  jobTitle            String?
  designation         String?
  role                String        // 'TENANT_IT', 'TENANT_ADMIN', 'CENTRAL_APPROVER', 'CENTRAL_IT'
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  password            String        // bcrypt hashed password

  // Security fields
  isActive            Boolean       @default(true)
  mustChangePassword  Boolean       @default(false)
  passwordExpiresAt   DateTime?     // null = no expiry; set to +72h on temp password reset
  authProvider        String        @default("CREDENTIALS") // 'CREDENTIALS' or 'MICROSOFT'
  createdAt           DateTime      @default(now())
  createdById         String?       // ID of CENTRAL_IT admin who created this account

  // Relations to requests
  requestsInitiated   LicenseRequest[] @relation("TenantIt")
  requestsApproved    LicenseRequest[] @relation("TenantAdmin")
  requestsAuthorized  LicenseRequest[] @relation("CentralApprover")
  requestsExecuted    LicenseRequest[] @relation("CentralIt")

  // ICT Survey Relations
  surveysSubmitted    IctSurvey[]   @relation("SurveySubmitter")
  surveysApproved     IctSurvey[]   @relation("SurveyApprover")
}

model LicenseCatalog {
  sku         String            @id
  name        String
  type        String            // 'USER', 'UPGRADE_USER', 'ADD_ON_S', 'ADD_ON_F'
  unitPrice   Float
  description String?           // Added for administrative context
  isActive    Boolean           @default(true) // Added for "Soft Delete" functionality
  lineItems   RequestLineItem[]
  allocations LicenseAllocation[]
  cpsTransactions CpsTransaction[]
}

model LicenseAllocation {
  id              String       @id @default(uuid())
  organizationId  String
  organization      Organization @relation(fields: [organizationId], references: [id])
  skuId           String
  sku             LicenseCatalog @relation(fields: [skuId], references: [sku])
  quantity        Int          @default(0)
  unitQty         Int          @default(12) // Default to 12 as per user's Excel sample
  lastUpdated     DateTime     @updatedAt

  @@unique([organizationId, skuId])
}

model LicenseRequest {
  id                String    @id @default(uuid())
  formNumber        String    @unique
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  requestDate       DateTime  @default(now())
  status            String    // 'DRAFT', 'PENDING_ORG_APPROVAL', 'PENDING_MDS_APPROVAL', 'PROVISIONING', 'COMPLETED'
  attachmentUrl     String?

  // Request-level justification and reference (used in official printed output)
  justification     String?   // e.g. "Request from ERA due to staff increase..."
  referenceLetterNo String?   // e.g. "203-AS/164/2026/1"

  tenantItId        String
  tenantIt          User      @relation("TenantIt", fields: [tenantItId], references: [id])

  tenantAdminId     String?
  tenantAdmin       User?     @relation("TenantAdmin", fields: [tenantAdminId], references: [id])

  centralApproverId String?
  centralApprover   User?     @relation("CentralApprover", fields: [centralApproverId], references: [id])

  centralItId       String?
  centralIt         User?     @relation("CentralIt", fields: [centralItId], references: [id])

  completionDate    DateTime?

  lineItems         RequestLineItem[]
  attachments       Attachment[]
}

model RequestLineItem {
  id               String         @id @default(uuid())
  requestId        String
  request          LicenseRequest @relation(fields: [requestId], references: [id])
  skuId            String
  sku              LicenseCatalog @relation(fields: [skuId], references: [sku])
  requestedQty     Int
  unitPriceAtTime  Float?         // Snapshot of price when request was created
  justification    String?
}

model Attachment {
  id           String         @id @default(uuid())
  requestId    String
  request      LicenseRequest @relation(fields: [requestId], references: [id])
  storedName   String         // UUID-based filename on disk (security: no user input)
  originalName String         // Original filename shown in UI
  mimeType     String
  sizeBytes    Int
  uploadedAt   DateTime       @default(now())
  uploadedById String
}

model SecurityAudit {
  id              String   @id @default(uuid())
  event           String   // 'FAILED_LOGIN', 'UNAUTHORIZED_ACCESS', 'RATE_LIMIT', 'MALWARE_BLOCKED'
  ipAddress       String
  userId          String?
  resource        String?  // The URL or ID attempted
  details         String?  // JSON string or description
  createdAt       DateTime @default(now())
}

model CpsRevision {
  id              String   @id @default(uuid())
  referenceNumber String   @unique // e.g. "CPS-2026-001"
  description     String?  // e.g. "Merger of Environment and Energy"
  effectiveDate   DateTime 
  status          String   // 'DRAFT', 'COMMITTED'
  createdAt       DateTime @default(now())
  committedAt     DateTime?
  createdBy       String   // User ID
  
  transactions    CpsTransaction[]
}

model CpsTransaction {
  id              String   @id @default(uuid())
  revisionId      String
  revision        CpsRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  
  fromOrgId       String?       // The org losing the licenses (can be null if new licenses are added via CPS)
  fromOrg         Organization? @relation("CpsFromOrg", fields: [fromOrgId], references: [id])
  
  toOrgId         String        // The org receiving the licenses
  toOrg           Organization  @relation("CpsToOrg", fields: [toOrgId], references: [id])
  
  skuId           String
  sku             LicenseCatalog @relation(fields: [skuId], references: [sku])
  
  quantityTransferred Int
}

// ═══════════════════════════════════════════════════════════════════════════════
// ICT SURVEY MODULE (Merged from ICT Portal)
// ═══════════════════════════════════════════════════════════════════════════════

model IctSurvey {
  id                String            @id @default(uuid())
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id])
  surveyYear        Int
  quarter           Int?
  submittedById     String
  submittedBy       User              @relation("SurveySubmitter", fields: [submittedById], references: [id])
  approvedById      String?
  approvedBy        User?             @relation("SurveyApprover", fields: [approvedById], references: [id])
  status            String            @default("DRAFT")
  referenceNumber   String            @unique
  submittedAt       DateTime?
  approvedAt        DateTime?
  reviewNotes       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  hardwareAssets    HardwareAsset[]
  softwareLicenses  SoftwareLicense[]
  infoSystems       InformationSystem[]
  networkAssets     NetworkAsset[]
  attachments       SurveyAttachment[]

  @@unique([organizationId, surveyYear, quarter])
}

model HardwareAsset {
  id                String    @id @default(uuid())
  surveyId          String
  survey            IctSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  assetTag          String?
  serialNumber      String?
  hostname          String?

  category          String    // DESKTOP, LAPTOP, SERVER, PRINTER, NETWORK_DEVICE, UPS, DISPLAY, OTHER
  make              String
  model             String

  processorModel    String?
  processorCores    Int?
  ramGb             Int?
  storageGb         Int?
  storageType       String?   // HDD, SSD, NVME
  gpuModel          String?
  displaySize       Float?

  currentOs         String?
  win11Compatible   String?   // YES, NO, UNKNOWN
  tpmVersion        String?
  secureBootEnabled Boolean?

  purchaseDate      DateTime?
  warrantyExpiry    DateTime?
  expectedLifeYears Int?              @default(5)
  depreciationMethod String?          @default("STRAIGHT_LINE")
  purchaseCostUsd   Float?
  currentValueUsd   Float?
  condition         String?           @default("OPERATIONAL")

  location          String?
  department        String?
  assignedToName    String?
  assignedToEmail   String?

  createdAt         DateTime          @default(now())

  m365Mappings      M365UserDeviceMap[]
}

model SoftwareLicense {
  id                String    @id @default(uuid())
  surveyId          String
  survey            IctSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  softwareName      String
  vendor            String?
  licenseType       String    // PERPETUAL, SUBSCRIPTION, OEM, OPEN_SOURCE, GOVERNMENT
  licenseKey        String?
  quantity          Int               @default(1)
  assignedQty       Int               @default(0)
  expiryDate        DateTime?
  annualCostUsd     Float?
  notes             String?

  createdAt         DateTime          @default(now())
}

model InformationSystem {
  id                String    @id @default(uuid())
  surveyId          String
  survey            IctSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  systemName        String
  systemType        String    // ERP, HRMS, CRM, CUSTOM_WEB, DATABASE, EMAIL, COLLABORATION, OTHER
  vendor            String?
  version           String?
  hostingType       String    // ON_PREMISE, CLOUD, HYBRID, SAAS
  url               String?
  databaseEngine    String?
  primaryLanguage   String?
  userCount         Int?
  criticality       String?   // CRITICAL, HIGH, MEDIUM, LOW
  dataClassification String?  // PUBLIC, INTERNAL, CONFIDENTIAL, SECRET
  backupFrequency   String?   // DAILY, WEEKLY, MONTHLY, NONE
  lastSecurityAudit DateTime?
  description       String?

  createdAt         DateTime          @default(now())
}

model NetworkAsset {
  id                String    @id @default(uuid())
  surveyId          String
  survey            IctSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  assetType         String    // ROUTER, SWITCH, FIREWALL, ACCESS_POINT, LOAD_BALANCER, CABLE_INFRA
  make              String?
  model             String?
  serialNumber      String?
  ipAddress         String?
  portCount         Int?
  bandwidth         String?
  managedType       String?   // MANAGED, UNMANAGED
  purchaseDate      DateTime?
  condition         String?   @default("OPERATIONAL")

  createdAt         DateTime          @default(now())
}

model SurveyAttachment {
  id                String    @id @default(uuid())
  surveyId          String
  survey            IctSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  category          String    // INVENTORY_SPREADSHEET, APPROVAL_LETTER, PROCUREMENT_PLAN, AUDIT_REPORT, OTHER
  storedName        String
  originalName      String
  mimeType          String
  sizeBytes         Int
  uploadedAt        DateTime  @default(now())
  uploadedById      String
}

model M365UserDeviceMap {
  id                String       @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])

  userEmail         String
  userName          String?
  department        String?

  hardwareAssetId   String?
  hardwareAsset     HardwareAsset? @relation(fields: [hardwareAssetId], references: [id])
  deviceDescription String?

  m365License       String?     // e.g. "Microsoft 365 E3", "Microsoft 365 Business Basic"
  assignedDate      DateTime?
  lastSyncDate      DateTime    @default(now())

  @@unique([organizationId, userEmail, m365License])
}

model AuditLog {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  userId          String
  userName        String
  userRole        String
  organizationId  String?
  action          String   // e.g. "SURVEY_SUBMIT", "ASSET_DELETE", "BULK_IMPORT"
  entityType      String   // e.g. "IctSurvey", "HardwareAsset"
  entityId        String?
  details         String?  // JSON string of changes
  ipAddress       String?
}
